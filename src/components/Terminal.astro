---
// 友好的终端(楼②实操关)。点「跑跑看」逐行"说话",不吓人。
// command = 要敲的命令;lines = 跑出来的回应(每行 {text, color?})
interface Line { text: string; color?: string; }
interface Props { command: string; lines: Line[]; title?: string; }
const { command, lines, title = '你的终端 · 跟着敲就行' } = Astro.props;
---
<div class="term-win" data-terminal data-cmd={command}>
  <div class="term-bar">
    <span class="dot" style="background:#E88B6F"></span>
    <span class="dot" style="background:#F2C879"></span>
    <span class="dot" style="background:#8FC79E"></span>
    <span class="term-name">{title}</span>
  </div>
  <div class="term-body">
    <div><span class="term-tilde">~</span> <span class="term-dollar">$</span> <span class="term-cmd">{command}</span><span class="term-cursor"></span></div>
    <div class="term-lines">
      {lines.map((l) => <div class="term-line" data-color={l.color ?? '#EDE3D0'} hidden>{l.text}</div>)}
    </div>
  </div>
</div>
<div class="term-actions">
  <button type="button" class="t-run" data-run>▶ 回车,跑跑看</button>
  <button type="button" class="t-copy" data-tcopy>📋 复制这行</button>
</div>

<style>
  .term-win { border-radius: 18px; overflow: hidden; box-shadow: 0 12px 30px rgba(58,44,30,0.22); border: 1.5px solid #2A2620; }
  .term-bar { background: #423C34; display: flex; align-items: center; gap: 8px; padding: 11px 14px; }
  .dot { width: 11px; height: 11px; border-radius: 50%; }
  .term-name { margin-left: 8px; font-size: 12.5px; color: #C9BCA6; }
  .term-body { background: #34302A; padding: 16px 16px 18px; font-family: var(--font-body); font-size: 14px; line-height: 1.9; color: #EDE3D0; min-height: 128px; }
  .term-tilde { color: #9AD0A6; }
  .term-dollar { color: #C9BCA6; }
  .term-cmd { color: #F6C98A; }
  .term-cursor { display: none; width: 9px; height: 17px; background: #EDE3D0; margin-left: 3px; vertical-align: -3px; animation: pf-blink 1.1s step-end infinite; }
  .term-cursor.on { display: inline-block; }
  .term-line { margin-top: 6px; }
  .term-actions { display: flex; gap: 10px; margin: 14px 0 24px; }
  .term-actions button { flex: 1; cursor: pointer; font-family: var(--font-hand); font-size: 15px; padding: 11px; border-radius: 13px; }
  .t-run { border: none; color: #fff; background: var(--c-green); box-shadow: 0 6px 14px rgba(127,185,142,0.32); }
  .t-copy { border: 1.5px solid var(--c-border); color: var(--c-orange-deep); background: var(--c-card); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-terminal]').forEach((win) => {
    const cursor = win.querySelector<HTMLElement>('.term-cursor')!;
    const lines = Array.from(win.querySelectorAll<HTMLElement>('.term-line'));
    lines.forEach((l) => (l.style.color = l.dataset.color || '#EDE3D0'));
    cursor.classList.add('on');
    const actions = win.nextElementSibling!;
    const runBtn = actions.querySelector<HTMLButtonElement>('[data-run]')!;
    const copyBtn = actions.querySelector<HTMLButtonElement>('[data-tcopy]')!;
    let timer: number | undefined;

    runBtn.addEventListener('click', () => {
      lines.forEach((l) => (l.hidden = true));
      cursor.classList.remove('on');
      let i = 0;
      clearInterval(timer);
      timer = window.setInterval(() => {
        if (i >= lines.length) { clearInterval(timer); return; }
        lines[i].hidden = false; i++;
      }, 520);
      runBtn.textContent = '↙ 再跑一次';
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard?.writeText(win.dataset.cmd || '').catch(() => {});
      copyBtn.textContent = '✓ 已复制';
      setTimeout(() => (copyBtn.textContent = '📋 复制这行'), 1600);
    });
  });
</script>
