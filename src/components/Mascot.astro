---
// 泡芙小姐 —— 站点吉祥物。金黄奶油泡芙,4 个表情。
// mood: hi 打招呼 / think 思考 / aha 原来如此 / clap 鼓掌
interface Props { mood?: 'hi' | 'think' | 'aha' | 'clap'; size?: number | string; }
const { mood = 'hi', size = 96 } = Astro.props;
const w = typeof size === 'number' ? `${size}px` : size;
---
<span class="mascot" style={`display:inline-block;width:${w};line-height:0;`}>
  <svg viewBox="0 0 120 134" width="100%" style="height:auto;display:block;overflow:visible;">
    <!-- 身体(各表情共用) -->
    <ellipse cx="60" cy="126" rx="30" ry="5" fill="rgba(120,90,50,0.12)"></ellipse>
    <ellipse cx="47" cy="120" rx="9" ry="6" fill="#E7B25A"></ellipse>
    <ellipse cx="73" cy="120" rx="9" ry="6" fill="#E7B25A"></ellipse>
    <path d="M60 13 q-7 2 -5 11 q5 -4 10 0 q3 -9 -5 -11 Z" fill="#F4CB7A" stroke="#E0A94E" stroke-width="2.4" stroke-linejoin="round"></path>
    <ellipse cx="60" cy="68" rx="45" ry="47" fill="#F6D389" stroke="#E0A94E" stroke-width="3"></ellipse>
    <ellipse cx="60" cy="74" rx="36" ry="34" fill="#FBE3AE" opacity="0.55"></ellipse>
    <ellipse cx="36" cy="80" rx="7.5" ry="4.5" fill="#F2A6A0" opacity="0.7"></ellipse>
    <ellipse cx="84" cy="80" rx="7.5" ry="4.5" fill="#F2A6A0" opacity="0.7"></ellipse>

    {mood === 'hi' && (
      <g>
        <ellipse cx="16" cy="82" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(18 16 82)"></ellipse>
        <ellipse cx="106" cy="46" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(-28 106 46)"></ellipse>
        <circle cx="46" cy="64" r="4.4" fill="#4A3A2C"></circle>
        <circle cx="74" cy="64" r="4.4" fill="#4A3A2C"></circle>
        <circle cx="47.4" cy="62.6" r="1.4" fill="#fff"></circle>
        <circle cx="75.4" cy="62.6" r="1.4" fill="#fff"></circle>
        <path d="M50 78 q10 9 20 0" stroke="#4A3A2C" stroke-width="3" fill="none" stroke-linecap="round"></path>
      </g>
    )}

    {mood === 'think' && (
      <g>
        <ellipse cx="16" cy="80" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(10 16 80)"></ellipse>
        <ellipse cx="98" cy="84" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(-42 98 84)"></ellipse>
        <circle cx="46" cy="61" r="4.4" fill="#4A3A2C"></circle>
        <circle cx="74" cy="61" r="4.4" fill="#4A3A2C"></circle>
        <circle cx="47.4" cy="59.6" r="1.4" fill="#fff"></circle>
        <circle cx="75.4" cy="59.6" r="1.4" fill="#fff"></circle>
        <path d="M54 80 q6 -3 12 0" stroke="#4A3A2C" stroke-width="3" fill="none" stroke-linecap="round"></path>
        <path d="M96 26 q1 -8 9 -8 q9 0 9 8 q0 7 -8 9 q-2 1 -2 5" stroke="#7FB98E" stroke-width="3.2" fill="none" stroke-linecap="round"></path>
        <circle cx="104" cy="48" r="2.6" fill="#7FB98E"></circle>
      </g>
    )}

    {mood === 'aha' && (
      <g>
        <ellipse cx="13" cy="64" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(38 13 64)"></ellipse>
        <ellipse cx="107" cy="64" rx="7" ry="11" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(-38 107 64)"></ellipse>
        <circle cx="46" cy="62" r="5.4" fill="#fff" stroke="#4A3A2C" stroke-width="2.4"></circle>
        <circle cx="74" cy="62" r="5.4" fill="#fff" stroke="#4A3A2C" stroke-width="2.4"></circle>
        <circle cx="46" cy="62.5" r="2.6" fill="#4A3A2C"></circle>
        <circle cx="74" cy="62.5" r="2.6" fill="#4A3A2C"></circle>
        <ellipse cx="60" cy="82" rx="5" ry="6.5" fill="#C9603F"></ellipse>
        <rect x="101" y="20" width="4.4" height="13" rx="2.2" fill="#F5A04C"></rect>
        <circle cx="103.2" cy="39" r="2.6" fill="#F5A04C"></circle>
        <path d="M22 30 l2 5 l5 2 l-5 2 l-2 5 l-2 -5 l-5 -2 l5 -2 Z" fill="#7FB98E"></path>
      </g>
    )}

    {mood === 'clap' && (
      <g>
        <ellipse cx="48" cy="98" rx="7.5" ry="10" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(24 48 98)"></ellipse>
        <ellipse cx="72" cy="98" rx="7.5" ry="10" fill="#F6D389" stroke="#E0A94E" stroke-width="2.6" transform="rotate(-24 72 98)"></ellipse>
        <path d="M40 62 q5 -6 10 0" stroke="#4A3A2C" stroke-width="3" fill="none" stroke-linecap="round"></path>
        <path d="M70 62 q5 -6 10 0" stroke="#4A3A2C" stroke-width="3" fill="none" stroke-linecap="round"></path>
        <path d="M48 76 q12 13 24 0 q-12 6 -24 0 Z" fill="#C9603F" stroke="#4A3A2C" stroke-width="2.6" stroke-linejoin="round"></path>
        <path d="M20 36 l1.6 4 l4 1.6 l-4 1.6 l-1.6 4 l-1.6 -4 l-4 -1.6 l4 -1.6 Z" fill="#F5A04C"></path>
        <path d="M100 30 l1.6 4 l4 1.6 l-4 1.6 l-1.6 4 l-1.6 -4 l-4 -1.6 l4 -1.6 Z" fill="#7FB98E"></path>
        <path d="M104 64 l1.3 3.4 l3.4 1.3 l-3.4 1.3 l-1.3 3.4 l-1.3 -3.4 l-3.4 -1.3 l3.4 -1.3 Z" fill="#F5A04C"></path>
      </g>
    )}
  </svg>
</span>
